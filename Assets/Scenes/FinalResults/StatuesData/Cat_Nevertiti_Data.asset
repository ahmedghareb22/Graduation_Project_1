  m_Name: Cat_Nevertiti_Data
  m_EditorClassIdentifier: Assembly-CSharp::StatueData
  statueName: "\u0627\u0644\u0645\u0644\u0643\u0629 \u0646\u0641\u0631\u062A\u064A\u062A\u064A
    \u0648\u0627\u0644\u0642\u0637\u0629 \u0627\u0644\u0645\u0635\u0631\u064A\u0629
    (\u0628\u0627\u0633\u062A\u062A)"
  info: "\u0625\u062D\u0646\u0627 \u062F\u0644\u0648\u0642\u062A\u064A \u0642\u062F\u0627\u0645
    \u0627\u062A\u0646\u064A\u0646 \u0645\u0646 \u0623\u062C\u0645\u0644 \u0627\u0644\u0631\u0645\u0648\u0632
    \u0627\u0644\u0644\u064A \u0628\u062A\u0639\u0628\u0631 \u0639\u0646 \u0627\u0644\u0631\u0648\u062D
    \u0627\u0644\u0645\u0635\u0631\u064A\u0629. \u0642\u0646\u0627\u0639 \u0627\u0644\u0645\u0644\u0643\u0629
    \u0646\u0641\u0631\u062A\u064A\u062A\u064A\u060C \u0627\u0644\u0644\u064A \u0627\u0633\u0645\u0647\u0627
    \u0645\u0639\u0646\u0627\u0647 '\u0627\u0644\u062C\u0645\u064A\u0644\u0629 \u0623\u062A\u062A'\u060C
    \u0628\u064A\u0648\u0631\u064A\u0643 \u062F\u0642\u0629 \u0627\u0644\u0646\u062D\u062A
    \u0648\u0627\u0644\u062C\u0645\u0627\u0644 \u0627\u0644\u0644\u064A \u0645\u0644\u0648\u0634
    \u0645\u062B\u064A\u0644. \u0648\u062C\u0646\u0628\u0647\u0627 \u062A\u0645\u062B\u0627\u0644
    \u0627\u0644\u0642\u0637\u0629 \u0627\u0644\u0633\u0648\u062F\u0627\u0621\u060C
    \u0648\u062F\u064A \u0643\u0627\u0646\u062A \u0628\u062A\u0631\u0645\u0632 \u0644\u0644\u0625\u0644\u0647\u0629
    '\u0628\u0627\u0633\u062A\u062A' \u062D\u0627\u0645\u064A\u0629 \u0627\u0644\u0628\u064A\u062A
    \u0648\u0627\u0644\u0639\u064A\u0644\u0629. \u0627\u0644\u0645\u0635\u0631\u064A
    \u0627\u0644\u0642\u062F\u064A\u0645 \u0643\u0627\u0646 \u0628\u064A\u062D\u062A\u0631\u0645
    \u0627\u0644\u0642\u0637\u0637 \u062C\u062F\u0627\u064B \u0648\u0628\u064A\u0639\u062A\u0628\u0631\u0647\u0627
    \u0631\u0645\u0632 \u0644\u0644\u0647\u062F\u0648\u0621 \u0648\u0627\u0644\u0648\u0641\u0627\u0621\u060C
    \u0648\u0641\u064A \u0646\u0641\u0633 \u0627\u0644\u0648\u0642\u062A \u0631\u0645\u0632
    \u0644\u0644\u0642\u0648\u0629 \u0648\u0627\u0644\u0634\u062C\u0627\u0639\u0629.
    \u0627\u0644\u0642\u0637\u0639\u062A\u064A\u0646 \u062F\u0648\u0644 \u0645\u0639
    \u0628\u0639\u0636 \u0628\u064A\u062D\u0633\u0633\u0648\u0646\u0627 \u0628\u062C\u0645\u0627\u0644
    \u0648\u0647\u062F\u0648\u0621 \u0627\u0644\u0631\u0648\u062D \u0641\u064A \u0645\u0635\u0631
    \u0627\u0644\u0642\u062F\u064A\u0645\u0629."
