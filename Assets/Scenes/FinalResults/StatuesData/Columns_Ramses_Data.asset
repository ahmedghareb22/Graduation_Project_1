  statueName: "\u0623\u0639\u0645\u062F\u0629 \u0631\u0645\u0633\u064A\u0633 \u0627\u0644\u062B\u0627\u0646\u064A"
  info: "\u0628\u0635 \u062D\u0648\u0627\u0644\u064A\u0643 \u0648\u0634\u0648\u0641
    \u0639\u0638\u0645\u0629 \u0627\u0644\u0635\u0631\u062D \u062F\u0647! \u0625\u062D\u0646\u0627
    \u062F\u0644\u0648\u0642\u062A\u064A \u0628\u064A\u0646 \u0623\u0639\u0645\u062F\u0629
    \u0627\u0644\u0645\u0644\u0643 \u0631\u0645\u0633\u064A\u0633 \u0627\u0644\u062B\u0627\u0646\u064A.
    \u0627\u0644\u062A\u0635\u0645\u064A\u0645 \u062F\u0647 \u0639\u0628\u0642\u0631\u064A\u060C
    \u0644\u0623\u0646 \u062A\u064A\u062C\u0627\u0646 \u0627\u0644\u0623\u0639\u0645\u062F\u0629
    \u0647\u0646\u0627 \u0645\u0639\u0645\u0648\u0644\u0629 \u0639\u0644\u0649 \u0634\u0643\u0644
    \u062D\u0632\u0645 \u0645\u0646 \u0646\u0628\u0627\u062A \u0627\u0644\u0628\u0631\u062F\u064A
    \u0648\u0647\u064A \u0644\u0633\u0647 \u0645\u0642\u0641\u0648\u0644\u0629. \u0627\u0644\u0645\u0635\u0631\u064A
    \u0627\u0644\u0642\u062F\u064A\u0645 \u0645\u0643\u0646\u0634 \u0628\u064A\u0628\u0646\u064A
    \u0645\u062C\u0631\u062F \u062D\u062C\u0631\u060C \u062F\u0647 \u0643\u0627\u0646
    \u0628\u064A\u062D\u0648\u0644 \u0627\u0644\u0645\u0639\u0628\u062F \u0644\u063A\u0627\u0628\u0629
    \u0645\u0642\u062F\u0633\u0629 \u0645\u0646 \u0627\u0644\u0646\u0628\u0627\u062A\u0627\u062A
    \u0627\u0644\u0644\u064A \u0628\u062A\u0637\u0644\u0639 \u0639\u0644\u0649 \u0636\u0641\u0627\u0641
    \u0627\u0644\u0646\u064A\u0644. \u0627\u0644\u0623\u0639\u0645\u062F\u0629 \u062F\u064A
    \u0645\u0634 \u0628\u0633 \u0634\u0627\u064A\u0644\u0629 \u0627\u0644\u0633\u0642\u0641\u060C
    \u062F\u064A \u0634\u0627\u064A\u0644\u0629 \u0646\u0642\u0648\u0634 \u0648\u0642\u0635\u0635
    \u0639\u0646 \u0627\u0646\u062A\u0635\u0627\u0631\u0627\u062A \u0627\u0644\u0645\u0644\u0643
    \u0648\u0639\u0644\u0627\u0642\u062A\u0647 \u0628\u0627\u0644\u0622\u0644\u0647\u0629\u060C
    \u0648\u0643\u0644 \u0639\u0645\u0648\u062F \u0645\u0646\u0647\u0645 \u062D\u0643\u0627\u064A\u0629
    \u0644\u0648\u062D\u062F\u0647."
