  m_Name: Kabsh_Data
  m_EditorClassIdentifier: Assembly-CSharp::StatueData
  statueName: "\u062A\u0645\u062B\u0627\u0644 \u0627\u0644\u0643\u0628\u0634 (\u0631\u0645\u0632
    \u0627\u0644\u0625\u0644\u0647 \u0622\u0645\u0648\u0646)"
  info: "\u062A\u0645\u062B\u0627\u0644 \u0627\u0644\u0643\u0628\u0634 \u0628\u0635
    \u064A\u0627 \u0635\u062F\u064A\u0642\u064A\u060C \u0627\u0644\u062A\u0645\u062B\u0627\u0644
    \u062F\u0647 \u0647\u0648 '\u0623\u0628\u0648 \u0627\u0644\u0647\u0648\u0644'
    \u0628\u0631\u062F\u0648\u060C \u0628\u0633 \u0628\u0631\u0623\u0633 \u0643\u0628\u0634
    \u0648\u062C\u0633\u0645 \u0623\u0633\u062F. \u062C\u0633\u0645 \u0627\u0644\u0623\u0633\u062F
    \u0647\u0646\u0627 \u0628\u064A\u0639\u0628\u0631 \u0639\u0646 \u0627\u0644\u0642\u0648\u0629
    \u0627\u0644\u062C\u0633\u062F\u064A\u0629 \u0644\u0644\u0645\u0644\u0643\u060C
    \u0648\u0631\u0623\u0633 \u0627\u0644\u0643\u0628\u0634 \u0628\u062A\u0639\u0643\u0633
    \u0627\u0644\u062D\u0643\u0645\u0629 \u0648\u0627\u0644\u0631\u0648\u062D\u0627\u0646\u064A\u0629
    \u0627\u0644\u0645\u0631\u062A\u0628\u0637\u0629 \u0628\u0627\u0644\u0625\u0644\u0647
    \u0622\u0645\u0648\u0646 \u0631\u064E\u0639. \u0648\u0632\u064A \u0645\u0627
    \u0623\u0646\u062A \u0634\u0627\u064A\u0641\u060C \u0641\u064A \u062A\u0645\u062B\u0627\u0644
    \u0635\u063A\u064A\u0631 \u0644\u0644\u0645\u0644\u0643 \u0631\u0645\u0633\u064A\u0633
    \u0627\u0644\u062B\u0627\u0646\u064A \u0648\u0627\u0642\u0641 \u0628\u064A\u0646
    \u0631\u062C\u0644\u064A\u0647 \u0648\u062A\u062D\u062A \u062F\u0642\u0646\u0647\u060C
    \u0643\u0623\u0646 \u0627\u0644\u0625\u0644\u0647 \u0628\u064A\u062D\u0645\u064A\u0647
    \u0648\u0628\u064A\u062F\u064A\u0644\u0647 \u0627\u0644\u0642\u0648\u0629 \u0627\u0644\u0625\u0644\u0647\u064A\u0629
    \u0639\u0634\u0627\u0646 \u064A\u062D\u0643\u0645 \u0645\u0635\u0631 "
  preRecordedAudio: {fileID: 8300000, guid: ca38815a5fbc3bb499ddadc909b27789, type: 3}
