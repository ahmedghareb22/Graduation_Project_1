  statueName: "\u0645\u0639\u0628\u062F \u0627\u0644\u0623\u0642\u0635\u0631 \u0648\u0645\u0633\u0644\u0627\u062A
    \u0631\u0645\u0633\u064A\u0633 \u0627\u0644\u062B\u0627\u0646\u064A"
  info: "\u0645\u0639\u0628\u062F \u0627\u0644\u0623\u0642\u0635\u0631 \u0648\u0645\u0633\u0644\u0627\u062A
    \u0631\u0645\u0633\u064A\u0633 \u0627\u0644\u062B\u0627\u0646\u064A \u0625\u062D\u0646\u0627
    \u062F\u0644\u0648\u0642\u062A\u064A \u0648\u0627\u0642\u0641\u064A\u0646 \u0642\u062F\u0627\u0645
    \u0639\u0638\u0645\u0629 \u0627\u0644\u0645\u062F\u062E\u0644 \u0627\u0644\u0631\u0626\u064A\u0633\u064A
    \u0644\u0645\u0639\u0628\u062F \u0627\u0644\u0623\u0642\u0635\u0631. \u0627\u0644\u0635\u0631\u062D
    \u0627\u0644\u0636\u062E\u0645 \u062F\u0647 \u0628\u0646\u0627\u0647 \u0627\u0644\u0645\u0644\u0643
    \u0631\u0645\u0633\u064A\u0633 \u0627\u0644\u062B\u0627\u0646\u064A\u060C \u0648\u0632\u064A
    \u0645\u0627 \u0623\u0646\u062A \u0634\u0627\u064A\u0641\u060C \u0641\u064A \u0642\u062F\u0627\u0645\u0647
    \u0645\u0633\u0644\u062A\u064A\u0646 \u0645\u0646 \u0627\u0644\u062C\u0631\u0627\u0646\u064A\u062A
    \u0627\u0644\u0648\u0631\u062F\u064A\u060C \u0628\u0635 \u0643\u0645\u0627\u0646
    \u0639\u0644\u0649 \u0627\u0644\u062A\u0645\u0627\u062B\u064A\u0644 \u0627\u0644\u0636\u062E\u0645\u0629
    \u0644\u0631\u0645\u0633\u064A\u0633 \u0648\u0647\u0648 \u0642\u0627\u0639\u062F
    \u0639\u0644\u0649 \u0639\u0631\u0634\u0647 \u0628\u064A\u062D\u0631\u0633 \u0627\u0644\u0628\u0648\u0627\u0628\u0629..
    \u0627\u0644\u0645\u062F\u062E\u0644 \u062F\u0647 \u0643\u0627\u0646 \u0628\u064A\u0628\u0647\u0631
    \u0623\u064A \u062D\u062F \u064A\u0632\u0648\u0631\u0647 \u0632\u0645\u0627\u0646\u060C
    \u0643\u0623\u0646\u0647 \u0628\u064A\u0642\u0648\u0644\u0643 \u0625\u0646\u0643
    \u062F\u0627\u062E\u0644 \u0645\u0643\u0627\u0646 \u0645\u0642\u062F\u0633 \u0648\u0645\u062D\u0645\u064A
    \u0628\u0642\u0648\u0629 \u0627\u0644\u0645\u0644\u0643 \u0648\u0627\u0644\u0622\u0644\u0647\u0629."
