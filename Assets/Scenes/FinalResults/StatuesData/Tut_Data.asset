  statueName: "\u0643\u0646\u0648\u0632 \u0627\u0644\u0645\u0644\u0643 \u062A\u0648\u062A
    \u0639\u0646\u062E \u0622\u0645\u0648\u0646"
  info: "\u0628\u0635 \u064A\u0627 \u0635\u062F\u064A\u0642\u064A\u060C \u0625\u062D\u0646\u0627
    \u062F\u0644\u0648\u0642\u062A\u064A \u0642\u062F\u0627\u0645 \u0623\u0647\u0645
    \u0642\u0637\u0639\u062A\u064A\u0646 \u0628\u064A\u0639\u0631\u0641\u0648\u0646\u0627
    \u062D\u0643\u0627\u064A\u0629 \u0627\u0644\u0645\u0644\u0643 \u0627\u0644\u0634\u0627\u0628
    \u062A\u0648\u062A \u0639\u0646\u062E \u0622\u0645\u0648\u0646. \u0627\u0644\u0642\u0646\u0627\u0639
    \u0627\u0644\u0630\u0647\u0628\u064A \u062F\u0647 \u0645\u0634 \u0645\u062C\u0631\u062F
    \u0641\u0646\u060C \u062F\u0647 \u0648\u062C\u0647 \u0645\u0635\u0631 \u0627\u0644\u0644\u064A
    \u0627\u0644\u0639\u0627\u0644\u0645 \u0643\u0644\u0647 \u0639\u0627\u0631\u0641\u0647\u060C
    \u0645\u0639\u0645\u0648\u0644 \u0645\u0646 \u062F\u0647\u0628 \u062E\u0627\u0644\u0635
    \u0639\u0634\u0627\u0646 \u064A\u0636\u0645\u0646 \u0644\u0644\u0645\u0644\u0643
    \u062D\u064A\u0627\u0629 \u0623\u0628\u062F\u064A\u0629. \u0648\u062C\u0646\u0628\u0647
    \u0627\u0644\u0639\u062C\u0644\u0629 \u0627\u0644\u062D\u0631\u0628\u064A\u0629
    \u0628\u062A\u0627\u0639\u062A\u0647\u060C \u0627\u0644\u0644\u064A \u0628\u062A\u062B\u0628\u062A
    \u0625\u0646 \u0627\u0644\u0645\u0644\u0643 \u0631\u063A\u0645 \u0635\u063A\u0631
    \u0633\u0646\u0647 \u0643\u0627\u0646 \u0628\u064A\u062A\u062F\u0631\u0628 \u0639\u0644\u0649
    \u0627\u0644\u0635\u064A\u062F \u0648\u0627\u0644\u062D\u0631\u0628. \u0627\u0644\u0639\u062C\u0644\u0629
    \u062F\u064A \u0643\u0627\u0646\u062A \u0633\u0631\u064A\u0639\u0629 \u062C\u062F\u0627\u064B
    \u0648\u062E\u0641\u064A\u0641\u0629\u060C \u0648\u0628\u062A\u0639\u062A\u0628\u0631
    '\u062F\u0628\u0627\u0628\u0629' \u0627\u0644\u0639\u0635\u0648\u0631 \u0627\u0644\u0642\u062F\u064A\u0645\u0629.
    \u0627\u0644\u0642\u0637\u0639\u062A\u064A\u0646 \u062F\u0648\u0644 \u0645\u0639
    \u0628\u0639\u0636 \u0628\u064A\u062D\u0643\u0648\u0627 \u0642\u0635\u0629 \u0645\u0644\u0643
    \u062C\u0645\u0639 \u0628\u064A\u0646 \u0627\u0644\u062C\u0645\u0627\u0644 \u0648\u0627\u0644\u0642\u0648\u0629."
