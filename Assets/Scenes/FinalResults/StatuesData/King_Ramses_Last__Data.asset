  statueName: "\u0627\u0644\u0645\u0644\u0643 \u0631\u0645\u0633\u064A\u0633 \u0627\u0644\u062B\u0627\u0646\u064A
    \u062C\u0627\u0644\u0633\u0627\u064B"
  info: "\u062D\u0646\u0627 \u062F\u0644\u0648\u0642\u062A\u064A \u0642\u062F\u0627\u0645
    \u0648\u0627\u062D\u062F \u0645\u0646 \u0623\u062C\u0645\u0644 \u062A\u0645\u0627\u062B\u064A\u0644
    \u0627\u0644\u0645\u0644\u0643 \u0631\u0645\u0633\u064A\u0633 \u0627\u0644\u062B\u0627\u0646\u064A
    \u0648\u0647\u0648 \u062C\u0627\u0644\u0633 \u0639\u0644\u0649 \u0639\u0631\u0634\u0647.
    \u0628\u0635 \u0639\u0644\u0649 \u0645\u0644\u0627\u0645\u062D \u0627\u0644\u0648\u0634
    \u0627\u0644\u0647\u0627\u062F\u064A\u0629 \u0648\u0627\u0644\u0648\u0627\u062B\u0642\u0629\u060C
    \u0648\u0627\u0644\u062A\u0627\u062C \u0627\u0644\u0645\u0632\u062F\u0648\u062C
    \u0627\u0644\u0644\u064A \u0628\u064A\u0645\u062B\u0644 \u062D\u0643\u0645\u0647
    \u0644\u0634\u0645\u0627\u0644 \u0648\u062C\u0646\u0648\u0628 \u0645\u0635\u0631.
    \u0631\u0645\u0633\u064A\u0633 \u0647\u0646\u0627 \u062D\u0627\u0637\u0637 \u0625\u064A\u062F\u0647
    \u0639\u0644\u0649 \u0631\u0643\u0628\u0647 \u0641\u064A \u0648\u0636\u0639\u064A\u0629
    \u0628\u062A\u0639\u0643\u0633 \u0627\u0644\u062B\u0628\u0627\u062A \u0648\u0627\u0644\u0642\u0648\u0629.
    \u0627\u0644\u062A\u0645\u062B\u0627\u0644 \u062F\u0647 \u0643\u0627\u0646 \u0631\u0633\u0627\u0644\u0629
    \u0644\u0643\u0644 \u0627\u0644\u0644\u064A \u064A\u0634\u0648\u0641\u0647 \u0625\u0646
    \u0627\u0644\u0645\u0644\u0643 \u0647\u0648 \u062D\u0627\u0645\u064A \u0627\u0644\u0628\u0644\u0627\u062F
    \u0648\u0627\u0644\u0648\u0633\u064A\u0637 \u0628\u064A\u0646 \u0627\u0644\u0634\u0639\u0628
    \u0648\u0627\u0644\u0622\u0644\u0647\u0629. \u062F\u0642\u0629 \u0627\u0644\u0646\u062D\u062A
    \u0641\u064A \u0627\u0644\u062A\u0641\u0627\u0635\u064A\u0644\u060C \u0632\u064A
    \u0627\u0644\u0639\u0636\u0644\u0627\u062A \u0648\u0627\u0644\u0644\u0628\u0627\u0633
    \u0627\u0644\u0645\u0644\u0643\u064A\u060C \u0628\u062A\u0648\u0631\u064A\u0646\u0627
    \u0639\u0638\u0645\u0629 \u0627\u0644\u0641\u0646 \u0641\u064A \u0627\u0644\u0623\u0633\u0631\u0629
    \u0627\u0644\u062A\u0633\u0639\u062A\u0627\u0634\u0631"
