  statueName: "\u062A\u0645\u062B\u0627\u0644 \u0623\u0628\u0648 \u0627\u0644\u0647\u0648\u0644"
  info: " \u062A\u0645\u062B\u0627\u0644 \u0623\u0628\u0648 \u0627\u0644\u0647\u0648\u0644
    (\u0646\u062E\u062A\u0646\u0628\u0648 \u0627\u0644\u0623\u0648\u0644) \u0628\u0631\u0623\u0633
    \u0625\u0646\u0633\u0627\u0646 \u0648\u062C\u0633\u0645 \u0623\u0633\u062F \u0627\u0644\u0631\u0623\u0633
    \u0647\u0646\u0627 \u0628\u062A\u0645\u062B\u0644 \u0630\u0643\u0627\u0621 \u0648\u062D\u0643\u0645\u0629
    \u0627\u0644\u0645\u0644\u0643\u060C \u0648\u0627\u0644\u062C\u0633\u0645 \u0628\u064A\u0645\u062B\u0644
    \u0642\u0648\u0629 \u0627\u0644\u0623\u0633\u062F \u0627\u0644\u062C\u0628\u0627\u0631\u0629.
    \u0627\u0644\u0646\u0648\u0639 \u062F\u0647 \u0645\u0646 \u0627\u0644\u062A\u0645\u0627\u062B\u064A\u0644
    \u0643\u0627\u0646 \u0628\u064A\u062A\u062D\u0637 \u0639\u0634\u0627\u0646 \u064A\u0643\u0648\u0646
    '\u062D\u0627\u0631\u0633' \u0644\u0644\u0645\u0643\u0627\u0646\u060C \u0648\u0628\u064A\u0631\u0645\u0632
    \u0644\u0644\u0645\u0644\u0643 \u0648\u0647\u0648 \u0641\u064A \u0643\u0627\u0645\u0644
    \u0642\u0648\u062A\u0647 \u0648\u0639\u0642\u0644\u0647 \u0628\u064A\u062D\u0645\u064A
    \u0645\u062F\u062E\u0644 \u0627\u0644\u0645\u0639\u0628\u062F. \u0628\u0635 \u0639\u0644\u0649
    \u0645\u0644\u0627\u0645\u062D \u0627\u0644\u0648\u0634\u060C \u0647\u062A\u0644\u0627\u0642\u064A\u0647\u0627
    \u0647\u0627\u062F\u064A\u0629 \u0648\u0648\u0627\u062B\u0642\u0629\u060C \u0648\u062F\u064A
    \u0643\u0627\u0646\u062A \u0631\u0633\u0627\u0644\u0629 \u0637\u0645\u0623\u0646\u064A\u0646\u0629
    \u0644\u0643\u0644 \u0627\u0644\u0644\u064A \u062F\u0627\u062E\u0644 \u064A\u0632\u0648\u0631
    \u0627\u0644\u0622\u0644\u0647\u0629 \u0632\u0645\u0627\u0646"
