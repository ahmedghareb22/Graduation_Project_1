    - target: {fileID: 7679054101852343544, guid: bf3c83e2217ee5043aa7a8ecc1978f79, type: 3}
      propertyPath: staticVoices.Array.data[0].textID
      value: "\u0623\u0647\u0644\u0627\u064B \u0628\u0643 \u064A\u0627 \u0635\u062F\u064A\u0642\u064A!
        \u0623\u0646\u0627 \u062D\u0648\u0631\u0633\u060C \u0645\u0631\u0634\u062F\u0643
        \u0627\u0644\u0633\u064A\u0627\u062D\u064A. \u062C\u0627\u0647\u0632 \u0646\u0628\u062F\u0623
        \u0627\u0644\u062C\u0648\u0644\u0629\u061F"
      objectReference: {fileID: 0}
    - target: {fileID: 7679054101852343544, guid: bf3c83e2217ee5043aa7a8ecc1978f79, type: 3}
      propertyPath: staticVoices.Array.data[1].textID
      value: "\u0644\u0648 \u062D\u0627\u0628\u0628 \u062A\u0639\u0631\u0641 \u0623\u0643\u062A\u0631
        \u0639\u0646 \u0627\u0644\u062A\u0645\u062B\u0627\u0644 \u062F\u0647 \u0623\u0646\u0627
        \u0645\u0648\u062C\u0648\u062F\u060C \u0623\u0648 \u0642\u0648\u0644\u064A
        '\u064A\u0644\u0627 \u0628\u064A\u0646\u0627' \u0639\u0634\u0627\u0646 \u0646\u0634\u0648\u0641
        \u0627\u0644\u0644\u064A \u0628\u0639\u062F\u0647"
      objectReference: {fileID: 0}
    - target: {fileID: 7679054101852343544, guid: bf3c83e2217ee5043aa7a8ecc1978f79, type: 3}
      propertyPath: staticVoices.Array.data[2].textID
      value: "\u0644\u062D\u062F \u0647\u0646\u0627 \u0648\u062C\u0648\u0644\u062A\u0646\u0627
        \u062E\u0644\u0635\u062A \u0627\u0646\u0647\u0627\u0631\u062F\u0647 \u0623\u062A\u0645\u0646\u064A
        \u062A\u0643\u0648\u0646 \u0627\u0633\u062A\u0645\u062A\u0639\u062A. \u0646\u0648\u0631\u062A\u0646\u064A!"
      objectReference: {fileID: 0}
    - target: {fileID: 7882451954814251634, guid: bf3c83e2217ee5043aa7a8ecc1978f79, type: 3}
